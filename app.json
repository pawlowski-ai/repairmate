{
  "expo": {
    "name": "MendWise",
    "slug": "mendwise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "repairmate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brainiac.repairmate",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to take photos of broken items for diagnosis.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photos to select images of broken items for diagnosis."
      }
    },
    "android": {
      "package": "com.brainiac.repairmate",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#3d3d3d"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/wordmark.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "90f7f4f0-9e8f-488b-8b8b-0e7dc62c6461"
      }
    },
    "owner": "lukinopawlalino"
  }
}
